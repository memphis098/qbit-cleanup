# qBittorrent
QBIT_URL=http://127.0.0.1:8080
QBIT_USERNAME=your_username
QBIT_PASSWORD=your_password

# Cleanup timing
STALL_MINUTES=120
NO_SEEDS_MINUTES=180
STRIKE_LIMIT=3

# Categories to manage. Leave blank for all incomplete torrents.
CATEGORY_FILTER=movies,tv

# Safety
DRY_RUN=true
DELETE_FILES=false

# State file
STATE_FILE=/opt/qbit-cleanup/state/qbit-cleanup-state.json

# Optional Radarr integration
RADARR_URL=http://your-radarr-ip:7878
RADARR_API_KEY=your_radarr_api_key
RADARR_RESEARCH_ENABLED=false
RADARR_RESEARCH_DRY_RUN=true
RADARR_RESEARCH_COOLDOWN_HOURS=12
RADARR_RESEARCH_MAX_RETRIES=2

# Optional Sonarr integration
SONARR_URL=http://your-sonarr-ip:8989
SONARR_API_KEY=your_sonarr_api_key
SONARR_RESEARCH_ENABLED=false
SONARR_RESEARCH_DRY_RUN=true
SONARR_RESEARCH_COOLDOWN_HOURS=12
SONARR_RESEARCH_MAX_RETRIES=2

# Optional nudge searches
NUDGE_ENABLED=false
NUDGE_COOLDOWN_HOURS=12
NUDGE_MAX_RETRIES=2

# Metadata retention
RESEARCH_RETENTION_DAYS=14
